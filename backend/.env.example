# --- Server ---
# Railway sets PORT automatically; locally use 3001.
PORT=3001

# Comma-separated origins allowed to call the API from the browser (your Vercel URL).
# Example: https://my-app.vercel.app
# Leave unset for permissive CORS (dev / quick demos).
CORS_ORIGIN=

# Path to SAP/jsonl data (relative to cwd or absolute). Default includes repo `data/`.
DATA_PATH=./data

# PostgreSQL (if your deployment uses it — e.g. Railway Postgres plugin)
DATABASE_URL=postgresql://user:password@localhost:5432/flowtrace

# --- OpenAI (Chat / LLM — keep secret; Railway Variables only in production) ---
OPENAI_API_KEY=

# --- Langfuse (optional observability — secrets stay on the backend only) ---
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com
